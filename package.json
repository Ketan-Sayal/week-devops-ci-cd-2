{
  "name": "test-app",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "db:generate":"cd packages/db && bunx prisma generate && cd ../..",
    "start:backend": "cd ./apps/backend && bun install && bun run start",
    "start:ws": "cd ./apps/ws && bun run start",
    "start:web": "cd ./apps/web && bun run start"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "prettier": "^3.7.4",
    "turbo": "^2.9.6",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.13",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
